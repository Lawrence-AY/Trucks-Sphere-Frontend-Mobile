{
  "expo": {
    "name": "TruckApp",
    "slug": "truck-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "truck-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truckapp.frontend",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to capture weigh-in and delivery locations.",
        "NSCameraUsageDescription": "We need camera access to capture weighment photos and receipts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.truckapp.frontend",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      "expo-secure-store",
      "expo-asset",
      "expo-status-bar",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
